# =============================================================================
# Configuracion de Kairos - plantilla de variables de entorno
# =============================================================================
# Copia este archivo a `.env` para personalizar tu setup local:
#     cp .env.example .env
#
# El archivo .env esta gitignoreado: NO se commitea.
# Cambia los defaults de password ANTES de cualquier deploy productivo.
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER=kairos
POSTGRES_PASSWORD=kairos
POSTGRES_DB=kairos
POSTGRES_HOST=kairos-db
POSTGRES_PORT=5432

# --- API ---
# URL completa que consume SQLAlchemy. Por defecto se arma con las vars de
# arriba; podes hardcodearla si tu DB no esta en docker-compose.
DATABASE_URL=postgresql+psycopg://kairos:kairos@kairos-db:5432/kairos

# --- Entorno ---
# development | production
KAIROS_ENV=development
